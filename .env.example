AI_PROVIDER=openai
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4o-mini

DEEPSEEK_API_KEY=your_deepseek_api_key_here
DEEPSEEK_MODEL=deepseek-v4-flash

# amoCRM. Хранить только на сервере/Vercel, никогда не добавлять токен в клиентский JavaScript.
AMOCRM_BASE_URL=https://lecmedea.amocrm.ru
AMOCRM_ACCESS_TOKEN=your_long_lived_amo_access_token
AMOCRM_PIPELINE_ID=11108006
AMOCRM_CHAT_STATUS_ID=87274334
AMOCRM_SITE_STATUS_ID=87274338

# Секретный URL вебхука amoCRM: https://<domain>/api/amo-webhook?key=<AMO_WEBHOOK_KEY>
AMO_WEBHOOK_KEY=generate_a_random_secret

# Необязательно: JSON с ID пользовательских полей amoCRM.
# Пример: {"UTM_SOURCE":123456,"PAGE_URL":123460,"FORM_NAME":123464}
AMOCRM_FIELD_MAP={}

# Необязательный общий ключ между Telegram-ботом и /api/amo-lead.
AMO_LEAD_API_KEY=

# Единый реестр Google Sheets + email-уведомление info@azimutclinic.ru.
# URL появляется после публикации google-apps-script/Code.gs как Web App.
LEADS_WEBHOOK_URL=https://script.google.com/macros/s/DEPLOYMENT_ID/exec
LEADS_WEBHOOK_SECRET=generate_a_different_random_secret
